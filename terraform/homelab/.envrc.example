# Copy this file to .envrc and fill in your values.
# direnv will automatically export these when you cd into this directory.
#   cp .envrc.example .envrc
#   direnv allow
#
# Secrets are pulled from Bitwarden. Unlock the vault before entering this directory:
#   export BW_SESSION=$(bw unlock --raw)
#
# Requires: bw (Bitwarden CLI) and jq

# ---------------------------------------------------------------------------
# Bitwarden vault helpers
# ---------------------------------------------------------------------------
if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  log_error "Bitwarden vault is locked."
  log_error "Run: export BW_SESSION=\$(bw unlock --raw)"
  return 1
fi

_bw_password() { bw get password "$1" 2>/dev/null; }
_bw_username() { bw get username "$1" 2>/dev/null; }
_bw_field()    { bw get item "$1" 2>/dev/null | jq -r ".fields[] | select(.name==\"$2\") | .value"; }

# ---------------------------------------------------------------------------
# ScaleComputing HyperCore provider credentials
# Bitwarden item: "Homelab - HyperCore"  (username: terraform, password: <hc_password>)
# ---------------------------------------------------------------------------
export HC_HOST="https://your-scalecomputing-cluster.example.com"
export HC_USERNAME="your-username"
export HC_PASSWORD=$(_bw_password "Homelab - HyperCore")
export HC_AUTH_METHOD="local"
export HC_TIMEOUT="60.0"

# ---------------------------------------------------------------------------
# Proxmox VE provider credentials (dh01 / pve01)
# Bitwarden item: "Homelab - Proxmox VE"
#   username: root  |  password: <ssh_password>
#   custom hidden field "api_token": root@pam!terraform=<uuid>
# Create token via: Datacenter → Permissions → API Tokens → Add
# ---------------------------------------------------------------------------
export PROXMOX_VE_ENDPOINT="https://pve01.home.lan:8006"
export PROXMOX_VE_API_TOKEN=$(_bw_field "Homelab - Proxmox VE" "api_token")
# Skip TLS verification (Proxmox ships with a self-signed cert)
export PROXMOX_VE_INSECURE="true"
# SSH credentials — required for the provider to perform disk operations on the node
export PROXMOX_VE_SSH_USERNAME=$(_bw_username "Homelab - Proxmox VE")
export PROXMOX_VE_SSH_PASSWORD=$(_bw_password "Homelab - Proxmox VE")

# ---------------------------------------------------------------------------
# Vultr Object Storage — Terraform S3 backend credentials
# Bitwarden item: "Homelab - Vultr S3"  (username: <access_key>, password: <secret_key>)
# ---------------------------------------------------------------------------
export AWS_ACCESS_KEY_ID=$(_bw_username "Homelab - Vultr S3")
export AWS_SECRET_ACCESS_KEY=$(_bw_password "Homelab - Vultr S3")

# ---------------------------------------------------------------------------
# Required Terraform variables (no defaults)
# ---------------------------------------------------------------------------

# IP address of the NAS providing NFS exports
export TF_VAR_nas_ip="192.168.1.x"

# IP or FQDN of the Proxmox node (pve01) — used by scp for cloud-init snippet uploads
export TF_VAR_dh01_node_ip="192.168.1.x"

# NFS export path on the NAS for the media library
export TF_VAR_nas_media_export="/volume1/media"

# NFS export path on the NAS for shared homelab files (acme.json etc.)
export TF_VAR_nas_shared_export="/volume1/docker"

# NFS export path on the NAS for backups
# export TF_VAR_nas_backups_export="/volume1/Backups"

# ---------------------------------------------------------------------------
# Optional Terraform variables (uncomment to override defaults)
# ---------------------------------------------------------------------------

# VM hostname and ScaleComputing display name (default: sc-docker-01)
# export TF_VAR_vm_name="sc-docker-01"

# vCPU count (default: 6)
# export TF_VAR_vcpu="6"

# RAM in MiB (default: 16384 = 16 GB)
# export TF_VAR_memory_mib="16384"

# OS disk size in GB (default: 100)
# export TF_VAR_disk_size_gb="100"

# VLAN ID (default: 0 = untagged)
# export TF_VAR_vlan="0"

# Local mount point for media on the VM (default: /media)
# export TF_VAR_media_mount_path="/mnt/media"

# Git URL of the homelab-gitops repo (default: https://github.com/locus313/homelab-gitops.git)
# export TF_VAR_repo_url="https://github.com/locus313/homelab-gitops.git"

# SSH import ID to pull keys from GitHub (default: gh:locus313)
# export TF_VAR_ssh_import_id="gh:locus313"

# Admin username created on the VM with sudo NOPASSWD and docker group (default: ubuntu)
# export TF_VAR_admin_user="ubuntu"

# System timezone (default: America/Los_Angeles)
# export TF_VAR_timezone="America/Los_Angeles"

# Clean up helpers
unset -f _bw_password _bw_username _bw_field
