# Environment variables for the terraform/portainer workspace.
#
# USAGE — choose one:
#
#   direnv (recommended):
#     cp .envrc.example .envrc
#     # fill in values, then:
#     direnv allow
#
#   Manual (no direnv):
#     cp .envrc.example .envrc
#     # fill in values, then source before every terraform command:
#     source .envrc
#
#   Inline (one-off):
#     env TF_VAR_portainer_api_key="ptr_..." terraform apply
#
# WORKFLOW:
#   1. Apply terraform/homelab/ to provision the VM
#   2. Wait for cloud-init to complete and Portainer to start
#   3. Log in to Portainer UI → Account (top-right) → Access tokens → Add token
#   4. Set TF_VAR_portainer_api_key below and run: terraform init && terraform apply
#
# NOTE: Portainer itself is bootstrapped manually and not managed here.
# This workspace requires Portainer to be running before `terraform apply`.
#
# Secrets are pulled from Bitwarden. Unlock the vault before entering this directory:
#   export BW_SESSION=$(bw unlock --raw)
#
# Requires: bw (Bitwarden CLI) and jq

# ---------------------------------------------------------------------------
# Bitwarden vault helpers
# ---------------------------------------------------------------------------
if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  log_error "Bitwarden vault is locked."
  log_error "Run: export BW_SESSION=\$(bw unlock --raw)"
  return 1
fi

_bw_password() { printf '%s' "$_BW_ITEMS" | jq -r "[.[] | select(.name==\"$1\") | .login.password] | map(select(. != null)) | first // empty"; }
_bw_username() { printf '%s' "$_BW_ITEMS" | jq -r "[.[] | select(.name==\"$1\") | .login.username] | map(select(. != null)) | first // empty"; }
_bw_field()    { printf '%s' "$_BW_ITEMS" | jq -r "[.[] | select(.name==\"$1\") | .fields[]? | select(.name==\"$2\") | .value] | first // empty"; }

# Fetch all items from the local vault cache in one call, then parse locally
_BW_ITEMS=$(bw list items 2>/dev/null)

# ---------------------------------------------------------------------------
# Vultr Object Storage — Terraform S3 backend credentials
# (same bucket as terraform/homelab — different state key)
# Bitwarden item: "Homelab - Vultr S3"  (username: <access_key>, password: <secret_key>)
# ---------------------------------------------------------------------------
export AWS_ACCESS_KEY_ID=$(_bw_username "Homelab - Vultr S3")
export AWS_SECRET_ACCESS_KEY=$(_bw_password "Homelab - Vultr S3")

# ---------------------------------------------------------------------------
# Portainer connection
# ---------------------------------------------------------------------------

# Portainer API URL — use the Traefik-routed domain once Traefik is deployed,
# or fall back to direct HTTPS: https://x.x.x.x:9443
export TF_VAR_portainer_endpoint="https://portainer.your-domain.com"

# Bitwarden item: "Homelab - Portainer"
#   password: <api_key>  |  custom hidden field "license_key": <ee_license>
# API key from Portainer UI: Account → Access tokens → Add token
export TF_VAR_portainer_api_key=$(_bw_password "Homelab - Portainer")

# Environment/endpoint ID in Portainer (local Docker = 1, i.e. dh02)
# export TF_VAR_portainer_endpoint_id="1"

# Endpoint ID for dh01 (registered Portainer agent — check Portainer UI → Environments)
export TF_VAR_dh01_endpoint_id="your-dh01-endpoint-id"

# Set to true only when using a self-signed cert (direct :9443 access)
# export TF_VAR_skip_ssl_verify="false"

# ---------------------------------------------------------------------------
# Git repository
# ---------------------------------------------------------------------------
# export TF_VAR_repo_url="https://github.com/locus313/homelab-gitops.git"
# export TF_VAR_repo_base_path="/opt/homelab-gitops"

# ---------------------------------------------------------------------------
# Common stack variables
# ---------------------------------------------------------------------------

# Base domain for all Traefik-routed services
export TF_VAR_traefik_base_domain="your-domain.com"

# Base path for persistent Docker service data (NFS-mounted)
# export TF_VAR_docker_base_path="/mnt/docker"

# Timezone (default: America/Los_Angeles)
# export TF_VAR_tz="America/Los_Angeles"

# User/group IDs for container file ownership
# export TF_VAR_puid="1000"
# export TF_VAR_pgid="1000"

# NFS media library mount point
# export TF_VAR_media_path="/mnt/media"

# NAS IP address (used in Traefik dynamic config for NAS-hosted services)
export TF_VAR_nas_ip="x.x.x.x"

# ---------------------------------------------------------------------------
# Traefik / CloudNS DNS-01 challenge
# Bitwarden item: "Homelab - CloudNS"  (username: <sub_auth_id>, password: <auth_password>)
# ---------------------------------------------------------------------------
export TF_VAR_cloudns_sub_auth_id=$(_bw_username "Homelab - CloudNS")
export TF_VAR_cloudns_auth_password=$(_bw_password "Homelab - CloudNS")
# export TF_VAR_lego_propagation_timeout="600"

# ---------------------------------------------------------------------------
# Portainer EE license
# Bitwarden item: "Homelab - Portainer"  (custom hidden field "license_key": <ee_license>)
# ---------------------------------------------------------------------------
export TF_VAR_portainer_license_key=$(_bw_field "Homelab - Portainer" "license_key")

# ---------------------------------------------------------------------------
# Gitea
# Bitwarden item: "Homelab - Gitea DB"  (password: <db_password>)
# ---------------------------------------------------------------------------
export TF_VAR_gitea_db_password=$(_bw_password "Homelab - Gitea DB")
# export TF_VAR_gitea_db_name="gitea"
# export TF_VAR_gitea_db_user="gitea"

# ---------------------------------------------------------------------------
# Gitea Mirror
# Bitwarden item: "Homelab - Gitea Mirror"  (password: <better_auth_secret>)
# ---------------------------------------------------------------------------
export TF_VAR_better_auth_secret=$(_bw_password "Homelab - Gitea Mirror")

# ---------------------------------------------------------------------------
# Homarr
# Bitwarden item: "Homelab - Homarr"  (password: <32-char hex encryption key>)
# ---------------------------------------------------------------------------
export TF_VAR_homarr_secret_encryption_key=$(_bw_password "Homelab - Homarr")

# ---------------------------------------------------------------------------
# Beszel
# Bitwarden item: "Homelab - Beszel"  (password: <ed25519 public key>)
# Retrieve from Beszel hub UI after first launch: Settings → Agent → Public key
# ---------------------------------------------------------------------------
export TF_VAR_beszel_public_key=$(_bw_password "Homelab - Beszel")

# ---------------------------------------------------------------------------
# Zerobyte
# Bitwarden item: "Homelab - Zerobyte"  (password: <app_secret>)
# ---------------------------------------------------------------------------
export TF_VAR_zerobyte_app_secret=$(_bw_password "Homelab - Zerobyte")

# ---------------------------------------------------------------------------
# Plex (optional — only needed for initial server claim)
# Bitwarden item: "Homelab - Plex"  (password: <claim_token>)
# Claim token from https://www.plex.tv/claim — expires in 4 minutes.
# Retrieve a fresh token, store it in Bitwarden, then uncomment before apply.
# Clear/re-comment after initial Plex setup to avoid errors on re-deploy.
# ---------------------------------------------------------------------------
# export TF_VAR_plex_claim=$(_bw_password "Homelab - Plex")

# ---------------------------------------------------------------------------
# Stirling-PDF
# Bitwarden item: "Homelab - Stirling PDF"  (password: <admin_password>)
# ---------------------------------------------------------------------------
export TF_VAR_stirling_security_initiallogin_password=$(_bw_password "Homelab - Stirling PDF")
# export TF_VAR_stirling_security_initiallogin_username="admin"

# ---------------------------------------------------------------------------
# Rackula
# Bitwarden item: "Homelab - Rackula"
#   password: <local_password>  |  custom hidden field "api_write_token": <token>
# ---------------------------------------------------------------------------
export TF_VAR_rackula_api_write_token=$(_bw_field "Homelab - Rackula" "api_write_token")
export TF_VAR_rackula_local_password=$(_bw_password "Homelab - Rackula")
# export TF_VAR_rackula_local_username="admin"
# export TF_VAR_rackula_auth_mode="none"
# Bitwarden item: "Homelab - Rackula"  (custom hidden field "auth_session_secret": <secret>)
# export TF_VAR_rackula_auth_session_secret=$(_bw_field "Homelab - Rackula" "auth_session_secret")

# ---------------------------------------------------------------------------
# MeTube (optional — override defaults if needed)
# ---------------------------------------------------------------------------
# export TF_VAR_metube_output_template="YouTube.com - %(title)s.%(ext)s"
# export TF_VAR_metube_ytdl_options="{}"

# ---------------------------------------------------------------------------
# HandBrake (optional)
# ---------------------------------------------------------------------------
# export TF_VAR_backup_path="/mnt/backups"

# ---------------------------------------------------------------------------
# Watchtower (optional)
# ---------------------------------------------------------------------------
# export TF_VAR_watchtower_cleanup="true"

# ---------------------------------------------------------------------------
# Code-Server
# Bitwarden item: "Homelab - Code-Server"
#   password: <code_server_password>  |  custom hidden fields:
#   "sudo_password": <sudo_password>  |  "ts_authkey": tskey-auth-...
# ---------------------------------------------------------------------------
export TF_VAR_code_server_password=$(_bw_password "Homelab - Code-Server")
export TF_VAR_code_server_sudo_password=$(_bw_field "Homelab - Code-Server" "sudo_password")
# Tailscale auth key from https://login.tailscale.com/admin/settings/keys
export TF_VAR_code_server_ts_authkey=$(_bw_field "Homelab - Code-Server" "ts_authkey")
# export TF_VAR_code_server_default_workspace="/config/workspace"
# export TF_VAR_code_server_ts_extra_args="--advertise-tags=tag:container --reset"

# ---------------------------------------------------------------------------
# OpenArchiver — self-hosted email archiving
# Bitwarden item: "Homelab - OpenArchiver"
#   password:               <postgres_password>
#   custom hidden fields:
#     meili_master_key:     $(openssl rand -hex 32)
#     redis_password:       $(openssl rand -hex 32)
#     jwt_secret:           $(openssl rand -hex 32)
#     encryption_key:       $(openssl rand -hex 32)
#     storage_encryption_key: $(openssl rand -hex 32)  (leave empty to disable at-rest encryption)
#
# One-shot setup (copy-paste into a shell with BW_SESSION set):
#   POSTGRES_PW=$(openssl rand -hex 32)
#   bw get template item \
#     | jq --arg pw "$POSTGRES_PW" \
#          '.name="Homelab - OpenArchiver" | .login.password=$pw
#            | .fields=[
#                {"name":"meili_master_key",   "value":"'"$(openssl rand -hex 32)"'","type":1},
#                {"name":"redis_password",      "value":"'"$(openssl rand -hex 32)"'","type":1},
#                {"name":"jwt_secret",          "value":"'"$(openssl rand -hex 32)"'","type":1},
#                {"name":"encryption_key",      "value":"'"$(openssl rand -hex 32)"'","type":1},
#                {"name":"storage_encryption_key","value":"'"$(openssl rand -hex 32)"'","type":1}
#              ]' \
#     | bw encode | bw create item
# ---------------------------------------------------------------------------
export TF_VAR_open_archiver_postgres_password=$(_bw_password "Homelab - OpenArchiver")
export TF_VAR_open_archiver_meili_master_key=$(_bw_field "Homelab - OpenArchiver" "meili_master_key")
export TF_VAR_open_archiver_redis_password=$(_bw_field "Homelab - OpenArchiver" "redis_password")
export TF_VAR_open_archiver_jwt_secret=$(_bw_field "Homelab - OpenArchiver" "jwt_secret")
export TF_VAR_open_archiver_encryption_key=$(_bw_field "Homelab - OpenArchiver" "encryption_key")
export TF_VAR_open_archiver_storage_encryption_key=$(_bw_field "Homelab - OpenArchiver" "storage_encryption_key")
# export TF_VAR_open_archiver_postgres_db="open_archive"
# export TF_VAR_open_archiver_postgres_user="admin"
# export TF_VAR_open_archiver_storage_local_root_path="/var/data/open-archiver"

# ---------------------------------------------------------------------------
# Netdata (deployed to both dh01 and dh02)
# Bitwarden item: "Homelab - Netdata"
#   password: <claim_token>  |  custom hidden field "rooms": <room_id>
# Get credentials from: https://app.netdata.cloud → Space → Connect Nodes
# ---------------------------------------------------------------------------
export TF_VAR_netdata_claim_token=$(_bw_password "Homelab - Netdata")
# export TF_VAR_netdata_claim_url="https://app.netdata.cloud"
export TF_VAR_netdata_claim_rooms=$(_bw_field "Homelab - Netdata" "rooms")

# Clean up helpers and cached vault data
unset -f _bw_password _bw_username _bw_field
unset _BW_ITEMS
