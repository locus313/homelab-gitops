# Common
DOCKER_BASE_PATH=/docker
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Mail Archiver Admin
MAIL_ARCHIVER_ADMIN_USER=admin
# Generate with: openssl rand -base64 16
MAIL_ARCHIVER_ADMIN_PASSWORD=your_secure_admin_password_here

# Mail Archiver Database
MAIL_ARCHIVER_DB_NAME=mailarchiver
MAIL_ARCHIVER_DB_USER=mailuser
# Generate with: openssl rand -base64 32
MAIL_ARCHIVER_DB_PASSWORD=your_secure_db_password_here

# Local Import (optional — uncomment volume and LocalImport env var in docker-compose.yml)
# MAIL_ARCHIVER_IMPORT_PATH=/path/to/your/mbox/files

# OIDC/OAuth SSO (optional — uncomment OAuth env vars in docker-compose.yml)
# See: https://github.com/s1t5/mail-archiver/blob/main/doc/OIDC_Implementation.md
# MAIL_ARCHIVER_OAUTH_AUTHORITY=https://sso.example.com
# MAIL_ARCHIVER_OAUTH_CLIENT_ID=your_client_id_here
# MAIL_ARCHIVER_OAUTH_CLIENT_SECRET=your_client_secret_here
# MAIL_ARCHIVER_OAUTH_DISPLAY_NAME=SSO
# MAIL_ARCHIVER_OAUTH_ADMIN_EMAIL=admin@example.com
