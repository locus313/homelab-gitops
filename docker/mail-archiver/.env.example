# Common
DOCKER_BASE_PATH=/docker
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Mail Archiver Admin
MAIL_ARCHIVER_ADMIN_USER=admin
# Generate with: openssl rand -base64 16
MAIL_ARCHIVER_ADMIN_PASSWORD=your_secure_admin_password_here

# Mail Archiver Database
MAIL_ARCHIVER_DB_NAME=mailarchiver
MAIL_ARCHIVER_DB_USER=mailuser
# Generate with: openssl rand -base64 32
MAIL_ARCHIVER_DB_PASSWORD=your_secure_db_password_here
