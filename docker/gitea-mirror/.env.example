# Gitea Mirror Configuration
# Copy this file to .env and update with your values

# === REQUIRED ===
DOCKER_BASE_PATH=/docker
PUID=1000
PGID=1000
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Session secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secure_random_secret_here_min_32_chars

# === OPTIONAL: GITHUB CONFIGURATION ===
# Configure via web UI after first login, or set here for automation

# GITHUB_USERNAME=your-github-username
# GITHUB_TOKEN=your-github-personal-access-token
# GITHUB_TYPE=personal  # Options: personal, organization

# Repository selection
# PRIVATE_REPOSITORIES=false
# PUBLIC_REPOSITORIES=true
# SKIP_FORKS=false
# MIRROR_STARRED=false
# MIRROR_ORGANIZATIONS=false

# === OPTIONAL: GITEA CONFIGURATION ===
# GITEA_URL=http://gitea:3000
# GITEA_TOKEN=your-gitea-api-token
# GITEA_USERNAME=your-gitea-username
# GITEA_ORGANIZATION=github-mirrors
# GITEA_MIRROR_INTERVAL=8h  # e.g. 30m, 1h, 8h, 24h

# === OPTIONAL: SCHEDULING ===
# SCHEDULE_ENABLED=false
# SCHEDULE_INTERVAL=3600  # Seconds or cron expression (e.g. "0 2 * * *")
# AUTO_IMPORT_REPOS=true

# === OPTIONAL: METADATA MIRRORING ===
# MIRROR_METADATA=false
# MIRROR_ISSUES=false
# MIRROR_PULL_REQUESTS=false
# MIRROR_RELEASES=false
# MIRROR_WIKI=false

# === OPTIONAL: SECURITY ===
# ENCRYPTION_SECRET=your-encryption-key  # generate with: openssl rand -base64 48
