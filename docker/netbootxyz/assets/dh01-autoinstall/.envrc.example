# Environment variables for dh01 Ubuntu autoinstall user-data generation.
#
# USAGE:
#   cp .envrc.example .envrc
#   # Fill in values below, then:
#   ../scripts/generate-autoinstall-userdata.sh
#
# The generate script renders user-data.tpl → user-data using these values.
# user-data (the generated output) is gitignored — only the template and this
# example file are committed to the public repo.

# ---------------------------------------------------------------------------
# Required — no defaults
# ---------------------------------------------------------------------------

# NAS IP address
export NAS_IP=""

# NFS export paths on the NAS
export NAS_MEDIA_EXPORT="/volume1/Media"
export NAS_SHARED_EXPORT="/volume1/docker"
export NAS_BACKUPS_EXPORT="/volume1/Backups"

# Admin user password hash — generate with: openssl passwd -6 'yourpassword'
export PASSWORD_HASH=""

# ---------------------------------------------------------------------------
# Optional — sensible defaults are used if not set
# ---------------------------------------------------------------------------

# Hostname for dh01
# export DH01_HOSTNAME="dh01"

# Admin username created during installation
# export ADMIN_USER="ubuntu"

# GitHub username for SSH key import (ssh-import-id-gh)
# export GITHUB_USER="locus313"

# homelab-gitops repo URL cloned on first boot
# export REPO_URL="https://github.com/locus313/homelab-gitops.git"
