# Common
DOCKER_BASE_PATH=/docker
PUID=1000
PGID=1000
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Storj Node - Storage path for node data
# This should be a large dedicated volume or mount point
STORAGE_PATH=/mnt/storj-data

# Storj Node - Operator wallet address (ERC-20 compatible, e.g. Ethereum or zkSync)
WALLET=0xYourEthereumWalletAddressHere

# Storj Node - Operator contact email for notifications
EMAIL=your-email@example.com

# Storj Node - Public IP/hostname and port (must be port-forwarded from your router)
# Format: external-ip-or-hostname:28967
ADDRESS=your-public-ip-or-hostname:28967

# Storj Node - Maximum storage to allocate to the network
STORAGE=2.0TB
