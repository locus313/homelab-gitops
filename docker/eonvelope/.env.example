# Common
DOCKER_BASE_PATH=/docker
PUID=1000
PGID=1000
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Eonvelope Database
EONVELOPE_DB_NAME=eonvelope
EONVELOPE_DB_USER=eonvelope
# Generate with: openssl rand -base64 32
EONVELOPE_DB_PASSWORD=your_secure_db_password_here
EONVELOPE_DB_ROOT_PASSWORD=your_secure_db_root_password_here

# Eonvelope Application
# Generate with: openssl rand -base64 50
EONVELOPE_SECRET_KEY=your_long_random_secret_key_here
EONVELOPE_ADMIN_PASSWORD=your_secure_admin_password_here
