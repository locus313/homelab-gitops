# OpenArchiver Environment Variables
# Copy this file to .env and update with your values

# Base path for Docker volumes
DOCKER_BASE_PATH=/docker

# Base domain for Traefik routing
TRAEFIK_BASE_DOMAIN=example.com

# --- Application Settings ---
NODE_ENV=production
PORT_FRONTEND=3000
PORT_BACKEND=4000

# The public-facing URL of your application (must match your Traefik domain)
APP_URL=https://open-archiver.example.com
ORIGIN=https://open-archiver.example.com

# Email sync frequency (cron expression; default: every minute)
SYNC_FREQUENCY='* * * * *'

# Set to 'true' to include Junk and Trash folders in the email archive
ALL_INCLUSIVE_ARCHIVE=false

# Number of concurrent mailbox ingestion jobs (increase on servers with more RAM)
INGESTION_WORKER_CONCURRENCY=5

# --- Storage Settings ---
# Path inside the container where files will be stored
# The compose file maps ${DOCKER_BASE_PATH}/open-archiver/data to this path
STORAGE_LOCAL_ROOT_PATH=/var/data/open-archiver

# Maximum request body size for file uploads (e.g., 512K, 100M, 5G, Infinity)
BODY_SIZE_LIMIT=100M

# Storage backend: 'local' or 's3'
STORAGE_TYPE=local

# --- Storage Encryption (optional) ---
# Generate with: openssl rand -hex 32
# If not set, files will not be encrypted at rest
STORAGE_ENCRYPTION_KEY=

# --- S3-Compatible Storage (only used if STORAGE_TYPE=s3) ---
STORAGE_S3_ENDPOINT=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_REGION=
# Set to 'true' for MinIO and other non-AWS S3 services
STORAGE_S3_FORCE_PATH_STYLE=false

# --- PostgreSQL ---
POSTGRES_DB=open_archive
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_postgres_password_here
DATABASE_URL=postgresql://admin:your_secure_postgres_password_here@postgres:5432/open_archive

# --- Meilisearch ---
# Generate with: openssl rand -hex 16
MEILI_MASTER_KEY=your_secure_meilisearch_master_key_here
MEILI_HOST=http://meilisearch:7700
MEILI_INDEXING_BATCH=500

# --- Redis / Valkey ---
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_TLS_ENABLED=false

# --- Security & Authentication ---
# Allow deletion of emails and ingestion sources
ENABLE_DELETION=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# JWT - IMPORTANT: Change to a long, random, secret string
JWT_SECRET=your_very_long_and_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Master encryption key for sensitive data (e.g., ingestion source credentials)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# --- Apache Tika Integration ---
TIKA_URL=http://tika:9998
