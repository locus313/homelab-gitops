# Common variables
DOCKER_BASE_PATH=/docker
PUID=1000
PGID=1000
TZ=America/Los_Angeles
TRAEFIK_BASE_DOMAIN=example.com

# Rackula Settings

# Internal port the API sidecar listens on
RACKULA_API_PORT=3001

# Optional: Bearer token to protect API PUT/DELETE routes (strongly recommended)
# Generate with: openssl rand -hex 32
RACKULA_API_WRITE_TOKEN=your_secure_api_write_token_here

# Authentication mode: none | local | oidc (default: none)
# Use "local" for single admin account, "oidc" for an identity provider
RACKULA_AUTH_MODE=none

# Required when RACKULA_AUTH_MODE is not "none" (minimum 32 characters)
# Generate with: openssl rand -hex 32
RACKULA_AUTH_SESSION_SECRET=

# Local auth credentials (required when RACKULA_AUTH_MODE=local)
# Minimum password length: 12 characters
RACKULA_LOCAL_USERNAME=admin
RACKULA_LOCAL_PASSWORD=your_secure_password_here

# Set to true for HTTPS deployments (Traefik handles SSL - keep true)
RACKULA_AUTH_SESSION_COOKIE_SECURE=true

# Keep false unless you explicitly need wildcard CORS (not recommended for production)
ALLOW_INSECURE_CORS=false
