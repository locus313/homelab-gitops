# Portainer
# Copy to .env and fill in values.
#
# CE (default):  docker compose up -d
# EE (Business): docker compose -f docker-compose.yml -f docker-compose.ee.yml up -d
#                (or add docker-compose.ee.yml as an additional compose file in Portainer GitOps)

# Base domain for Traefik routing — Portainer accessible at portainer.${TRAEFIK_BASE_DOMAIN}
# Routing is configured in docker/traefik/config/dynamic/ (not via labels)
TRAEFIK_BASE_DOMAIN=yourdomain.com

# Path where Portainer data is stored (synced by Syncthing for resilience)
DOCKER_BASE_PATH=/docker

# Timezone
TZ=America/Los_Angeles

# Portainer Business Edition license key — only required when using docker-compose.ee.yml
PORTAINER_LICENSE_KEY=your-portainer-be-license-key
