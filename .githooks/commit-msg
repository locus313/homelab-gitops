#!/bin/bash
# Validates commit messages follow the Conventional Commits specification.
#
# Hooks in this directory:
#   pre-commit  → YAML lint, 'latest' image tag detection, secret scanning
#   commit-msg  → Conventional Commits format + 100-char subject limit (this file)
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Types:
#   feat     → Added section in changelog
#   fix      → Fixed section in changelog
#   chore    → Changed (includes deps, ci, build, etc.)
#   docs     → Changed
#   refactor → Changed
#   perf     → Changed
#   revert   → Changed
#
# Examples:
#   feat(docker/portainer): add initial Portainer stack
#   fix(traefik): correct missing start_period in healthcheck
#   chore(terraform/homelab): add nfs_backup_export variable
#   docs: update README with current service list

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Skip merge commits, reverts auto-generated by git, fixup, squash
if echo "$COMMIT_MSG" | grep -qE "^(Merge (branch|pull|remote)|Revert \"|fixup! |squash! )"; then
    exit 0
fi

# Skip Dependabot commits (they're already conventional)
if echo "$COMMIT_MSG" | grep -qE "^chore\(deps\):"; then
    exit 0
fi

# Skip empty lines / WIP commits if desired (remove if you want to enforce on WIP)
if echo "$COMMIT_MSG" | grep -qE "^(WIP|wip):?\s"; then
    exit 0
fi

# Conventional Commits pattern: type(scope)!: description
PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9/_., :-]+\))?(!)?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "" >&2
    echo "  ✗  Commit message does not follow Conventional Commits format." >&2
    echo "" >&2
    echo "     Format:  <type>(<scope>): <description>" >&2
    echo "     Example: feat(docker/portainer): add initial Portainer stack" >&2
    echo "" >&2
    echo "     Types: feat  fix  docs  style  refactor  perf" >&2
    echo "            test  build  ci  chore  revert" >&2
    echo "" >&2
    echo "     Scopes are optional but encouraged (e.g., docker/traefik, terraform/homelab)." >&2
    echo "     Add ! before : for breaking changes: feat!: drop TLS 1.0 support" >&2
    echo "" >&2
    echo "     Your message: $COMMIT_MSG" >&2
    echo "" >&2
    exit 1
fi

# Enforce max 100 chars on subject line
LENGTH=${#COMMIT_MSG}
if [[ $LENGTH -gt 100 ]]; then
    echo "" >&2
    echo "  ✗  Commit subject is $LENGTH characters (max 100). Please shorten it." >&2
    echo "" >&2
    exit 1
fi

exit 0
